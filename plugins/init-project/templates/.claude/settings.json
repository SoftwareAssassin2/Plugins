{
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  },
  "extraKnownMarketplaces": {
    "plugins": {
      "source": {
        "source": "github",
        "repo": "SoftwareAssassin2/Plugins"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/collaboration-inbox.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/claude-md-reminder.sh"
          }
        ]
      }
    ]
  }
}
