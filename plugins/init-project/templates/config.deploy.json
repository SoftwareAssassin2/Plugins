{
  "systems": [
    {
      "name": "postgres",
      "docker": false,
      "host": "{{POSTGRES_HOST}}",
      "container_host": "{{POSTGRES_HOST}}",
      "container_port": 5432,
      "port": 5432,
      "owner_password": "{{POSTGRES_OWNER_PASSWORD}}",
      "migrator_password": "{{POSTGRES_MIGRATOR_PASSWORD}}",
      "api_password": "{{POSTGRES_API_PASSWORD}}"
    },
    {
      "name": "keycloak",
      "docker": false,
      "host": "{{KEYCLOAK_HOST}}",
      "container_host": "{{KEYCLOAK_HOST}}",
      "container_port": 8080,
      "port": 8080,
      "realm": "{{KEYCLOAK_REALM}}",
      "public_url": "{{KEYCLOAK_PUBLIC_URL}}",
      "admin_user": "admin",
      "admin_password": "{{KEYCLOAK_ADMIN_PASSWORD}}",
      "webapp_client_id": "webapp",
      "marketingsite_client_id": "marketingsite",
      "api_client_id": "api",
      "api_client_secret": "{{KEYCLOAK_API_CLIENT_SECRET}}"
    },
    { "name": "Framework" },
    { "name": "DataAccess" },
    { "name": "BusinessLogic" },
    {
      "name": "Api",
      "host": "{{API_HOST}}",
      "port": 5080
    },
    {
      "name": "MarketingSite",
      "realm_url": "{{KEYCLOAK_PUBLIC_URL}}/realms/{{KEYCLOAK_REALM}}",
      "public_client_id": "marketingsite"
    },
    {
      "name": "WebApp",
      "realm_url": "{{KEYCLOAK_PUBLIC_URL}}/realms/{{KEYCLOAK_REALM}}",
      "public_client_id": "webapp"
    },
    { "name": "SampleApp" }
  ],
  "services": {
    "claude-api": { "base_url": "{{CLAUDE_API_BASE_URL}}", "api_key": "{{CLAUDE_API_KEY}}" },
    "openai-api": { "base_url": "{{OPENAI_API_BASE_URL}}", "api_key": "{{OPENAI_API_KEY}}" }
  }
}
